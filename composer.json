{
  "name": "comphp/web",
  "type": "library",
  "description": "Web application integration layer combining HTTP, routing, actions, views, assets, and runtime support.",
  "license": "MIT",
  "version": "0.3",
  "autoload": {
    "psr-4": {
      "CommonPHP\\Web\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CommonPHP\\Web\\Tests\\": "tests/"
    }
  },
  "require": {
    "php": "^8.5",
    "comphp/runtime": "^0.3",
    "comphp/http": "^0.3",
    "comphp/router": "^0.3",
    "comphp/ui": "^0.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^13.1",
    "friendsofphp/php-cs-fixer": "^3.95"
  }
}